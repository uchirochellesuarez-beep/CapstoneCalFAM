# Backend example environment file
# Default backend port (this server)
PORT=3000

# ── Gastos forecasting ───────────────────────────────────────────────────────
# Node backend tumatawag sa dedicated Python ML service (`ml-service/`) kapag nakatakda ang ML_API_URL.
# Kung hindi tumatakbo ang Python o unreachable, otomatik na Node OLS fallback.
#
# Buksan ang ML server (hiwalay na terminal):
#   cd ml-service && python -m venv .venv && .venv\Scripts\activate && pip install -r requirements.txt && uvicorn main:app --host 127.0.0.1 --port 5001
#
# Gastos forecast — bundled samples (automatic by default):
# - Sa startup, idinadaan ang seed mula data/expense_training_samples/<id>/*.json (idempotent).
#   Itigil ito gamit ang:
# EXPENSE_FORECAST_DISABLE_STARTUP_SAMPLE_SEED=1
# - Kung kulang ang DB rows, otomatik isasama ang JSON panel kapag may folder para sa farmer_id —
#   maliban kung:
# EXPENSE_FORECAST_DISABLE_BUNDLED_SAMPLES=1
# - Kung nakatakda ang listahan (non-empty), limitado lamang ang IDs na iyong bibigyang panel:
# EXPENSE_FORECAST_SAMPLE_FARMER_IDS=69,70
# EXPENSE_FORECAST_AUGMENT_IF_DB_UNDER=4
# ML_API_TIMEOUT_MS=15000

# Base URL ng Python FastAPI (walang trailing slash)
ML_API_URL=http://127.0.0.1:5001

# Frontend origin (for CORS). Set to the dev frontend origin (e.g. http://localhost:5173)
FRONTEND_ORIGIN=http://localhost:5173

# SMS notifications (seed / fertilizer approvals sa Farmer Income Hub)
# Set SMS_ENABLED=true at i-on ang provider na pipiliin mo.
#
# Inirerekomenda: PhilSMS (hosted API, walang Android gateway app sa phone)
# Dokumentasyon: https://app.philsms.com/developers/documentation
# Kumuha ng API token + registered sender_id mula sa PhilSMS dashboard.
#
# SMS_PROVIDER=philsms
# SMS_PHILSMS_API_TOKEN=
# SMS_PHILSMS_SENDER_ID=CALFFA
# SMS_PHILSMS_ENDPOINT=https://dashboard.philsms.com/api/v3/sms/send
# SMS_PHILSMS_TYPE=plain
SMS_ENABLED=false
SMS_PROVIDER=android_gateway
SMS_TIMEOUT_MS=10000

# PhilSMS (kung SMS_PROVIDER=philsms)
SMS_PHILSMS_API_TOKEN=
SMS_PHILSMS_SENDER_ID=
SMS_PHILSMS_ENDPOINT=https://dashboard.philsms.com/api/v3/sms/send
SMS_PHILSMS_TYPE=plain

# Android SMS gateway settings (SMS_PROVIDER=android_gateway — luma/TextBee-style HTTP → phone)
SMS_ANDROID_ENDPOINT=http://192.168.1.100:3000/send-sms
SMS_ANDROID_AUTH_TOKEN=
SMS_ANDROID_RECIPIENT_FIELD=phoneNumber
SMS_ANDROID_MESSAGE_FIELD=message
SMS_ANDROID_EXTRA_PAYLOAD={}

# Optional real Android-to-SMS provider via httpSMS
# Install the httpSMS Android app on the phone, pair it with your account,
# then use the API key and the phone/SIM number below.
# SMS_PROVIDER=httpsms
# SMS_HTTPSMS_API_KEY=
# SMS_HTTPSMS_FROM=+639171234567
# SMS_HTTPSMS_ENDPOINT=https://api.httpsms.com/v1/messages/send

# Optional API provider example: Semaphore
# SMS_PROVIDER=semaphore
# SMS_SEMAPHORE_API_KEY=
# SMS_SEMAPHORE_SENDER_NAME=CALFFA
# SMS_SEMAPHORE_ENDPOINT=https://api.semaphore.co/api/v4/messages
