# Backend example environment file
# Default backend port (this server)
PORT=3000

# ML API URL: point to the Python ML service. Default points to port 5001 to
# avoid colliding with this backend server which uses port 5000.
ML_API_URL=http://127.0.0.1:5001

# Frontend origin (for CORS). Set to the dev frontend origin (e.g. http://localhost:5173)
FRONTEND_ORIGIN=http://localhost:5173

# SMS notifications
# Set SMS_ENABLED=true to activate SMS delivery.
# Recommended zero-cost option in the Philippines:
# Use an Android phone running an SMS gateway app that exposes a local HTTP API.
# The backend will call SMS_ANDROID_ENDPOINT and the phone will send the text using its SIM.
SMS_ENABLED=false
SMS_PROVIDER=android_gateway
SMS_TIMEOUT_MS=10000

# Android SMS gateway settings
SMS_ANDROID_ENDPOINT=http://192.168.1.100:3000/send-sms
SMS_ANDROID_AUTH_TOKEN=
SMS_ANDROID_RECIPIENT_FIELD=phoneNumber
SMS_ANDROID_MESSAGE_FIELD=message
SMS_ANDROID_EXTRA_PAYLOAD={}

# Optional real Android-to-SMS provider via httpSMS
# Install the httpSMS Android app on the phone, pair it with your account,
# then use the API key and the phone/SIM number below.
# SMS_PROVIDER=httpsms
# SMS_HTTPSMS_API_KEY=
# SMS_HTTPSMS_FROM=+639171234567
# SMS_HTTPSMS_ENDPOINT=https://api.httpsms.com/v1/messages/send

# Optional API provider example: Semaphore
# SMS_PROVIDER=semaphore
# SMS_SEMAPHORE_API_KEY=
# SMS_SEMAPHORE_SENDER_NAME=CALFFA
# SMS_SEMAPHORE_ENDPOINT=https://api.semaphore.co/api/v4/messages
